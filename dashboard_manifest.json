{
  "pages": [
    {
      "id": "play",
      "title": "Play",
      "icon": "play",
      "widgets": [
        {
          "id": "tictactoe_iframe",
          "type": "iframe",
          "label": "Tic-Tac-Toe Hall",
          "rpc_method": "dashboard.get_play_iframe_url",
          "rpc_params": {},
          "width": "full",
          "height": 760
        }
      ]
    },
    {
      "id": "overview",
      "title": "Overview",
      "icon": "chart-bar",
      "widgets": [
        {
          "id": "open_tables",
          "type": "stat_card",
          "label": "Open Tables",
          "rpc_method": "dashboard.get_open_tables_count",
          "rpc_params": {},
          "width": "third"
        },
        {
          "id": "active_players",
          "type": "stat_card",
          "label": "Players Online",
          "rpc_method": "dashboard.get_active_players_count",
          "rpc_params": {},
          "width": "third"
        },
        {
          "id": "games_today",
          "type": "stat_card",
          "label": "Games Played (24h)",
          "rpc_method": "dashboard.get_games_today",
          "rpc_params": {},
          "width": "third"
        },
        {
          "id": "games_trend",
          "type": "chart",
          "label": "Games Played (7d)",
          "rpc_method": "dashboard.get_games_trend",
          "rpc_params": { "period": "7d" },
          "chart_type": "line",
          "width": "full"
        }
      ]
    },
    {
      "id": "leaderboard",
      "title": "Leaderboard",
      "icon": "trophy",
      "widgets": [
        {
          "id": "global_leaderboard",
          "type": "table",
          "label": "Top 25 Players (Cross-Server)",
          "rpc_method": "dashboard.get_leaderboard",
          "rpc_params": { "limit": 25 },
          "width": "full",
          "columns": [
            { "key": "rank",       "label": "#",        "width": 60,  "align": "right"  },
            { "key": "username",   "label": "Player",   "align": "left"  },
            { "key": "elo",        "label": "ELO",      "width": 100, "align": "right" },
            { "key": "wins",       "label": "Wins",     "width": 80,  "align": "right" },
            { "key": "losses",     "label": "Losses",   "width": 80,  "align": "right" },
            { "key": "draws",      "label": "Draws",    "width": 80,  "align": "right" },
            { "key": "win_pct",    "label": "Win %",    "width": 90,  "align": "right" },
            { "key": "best_streak","label": "Best Streak","width": 110,"align": "right" }
          ]
        }
      ]
    },
    {
      "id": "settings",
      "title": "Settings",
      "icon": "cog",
      "widgets": [
        {
          "id": "settings_form",
          "type": "form",
          "label": "Plugin Settings",
          "rpc_method": "dashboard.get_settings",
          "save_rpc_method": "dashboard.save_settings",
          "rpc_params": {},
          "width": "full",
          "fields": [
            {
              "key": "game_server_url",
              "label": "Game server URL",
              "type": "text",
              "placeholder": "https://tictactoe.mmomaid.cloud"
            },
            {
              "key": "shared_secret",
              "label": "Plugin → Game Server shared secret",
              "type": "secret",
              "placeholder": "(leave blank to keep current)"
            },
            {
              "key": "announce_channel_id",
              "label": "Match-result announce channel ID",
              "type": "text",
              "placeholder": "Optional. Discord channel ID."
            },
            {
              "key": "turn_timer_seconds",
              "label": "Turn timer (seconds)",
              "type": "integer",
              "placeholder": "30"
            }
          ]
        }
      ]
    }
  ]
}
